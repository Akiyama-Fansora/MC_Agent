# Copy this file to .env and fill only the providers you use.
# Never commit .env.

# Cloud LLM used by MCagent/CrawlerAgent planners when configured.
LLM_API_KEY=

# Optional search/scrape providers for CrawlerAgent.
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=

# Optional local model overrides.
MCAGENT_OLLAMA_BASE_URL=http://localhost:11434/v1
MCAGENT_OLLAMA_MODEL=qwen3-4b-agent-16k:latest

# Optional frontend directory override. Leave empty to use ./frontend.
AGENT_CONSOLE_DIR=
